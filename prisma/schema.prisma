generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth.js Models ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Domain Models ──────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  image       String?
  preferences Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  tasks         Task[]
  units         Unit[]
  weeklyPlans   WeeklyPlan[]
  dailyPlans    DailyPlan[]
  timerSessions TimerSession[]

  @@map("users")
}

model Project {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  name      String
  color     String        @default("#6366f1")
  status    ProjectStatus @default(active)
  createdAt DateTime      @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId, status])
  @@map("projects")
}

model Task {
  id             String     @id @default(uuid())
  projectId      String     @map("project_id")
  userId         String     @map("user_id")
  title          String
  description    String?    @db.Text
  status         TaskStatus @default(backlog)
  estimatedUnits Int        @default(1) @map("estimated_units")
  completedUnits Int        @default(0) @map("completed_units")
  createdAt      DateTime   @default(now()) @map("created_at")
  completedAt    DateTime?  @map("completed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  units   Unit[]

  @@index([userId, status])
  @@index([projectId])
  @@map("tasks")
}

model Unit {
  id                    String     @id @default(uuid())
  taskId                String     @map("task_id")
  userId                String     @map("user_id")
  label                 String?
  status                UnitStatus @default(pending)
  actualDurationSeconds Int?       @map("actual_duration_seconds")
  actualUnitsConsumed   Int?       @map("actual_units_consumed")
  completedAt           DateTime?  @map("completed_at")
  createdAt             DateTime   @default(now()) @map("created_at")

  task           Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledUnits ScheduledUnit[]
  timerSessions  TimerSession[]

  @@index([userId, status])
  @@index([taskId])
  @@map("units")
}

model WeeklyPlan {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  weekStartDate DateTime         @map("week_start_date") @db.Date
  targetUnits   Int              @map("target_units")
  status        WeeklyPlanStatus @default(planning)
  createdAt     DateTime         @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyPlans DailyPlan[]

  @@unique([userId, weekStartDate])
  @@map("weekly_plans")
}

model DailyPlan {
  id           String   @id @default(uuid())
  weeklyPlanId String   @map("weekly_plan_id")
  userId       String   @map("user_id")
  date         DateTime @db.Date
  targetUnits  Int      @map("target_units")

  weeklyPlan     WeeklyPlan      @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledUnits ScheduledUnit[]

  @@unique([weeklyPlanId, date])
  @@index([userId, date])
  @@map("daily_plans")
}

model ScheduledUnit {
  id          String @id @default(uuid())
  dailyPlanId String @map("daily_plan_id")
  unitId      String @map("unit_id")
  sortOrder   Int    @map("sort_order")

  dailyPlan DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
  unit      Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([dailyPlanId, unitId])
  @@index([dailyPlanId, sortOrder])
  @@map("scheduled_units")
}

model TimerSession {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  unitId    String?          @map("unit_id")
  type      TimerSessionType
  startedAt DateTime         @default(now()) @map("started_at")
  endedAt   DateTime?        @map("ended_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@map("timer_sessions")
}

// ─── Enums ──────────────────────────────────────────────────────────

enum ProjectStatus {
  active
  archived
}

enum TaskStatus {
  backlog
  planned
  in_progress
  done
}

enum UnitStatus {
  pending
  scheduled
  in_progress
  completed
  skipped
}

enum WeeklyPlanStatus {
  planning
  active
  completed
}

enum TimerSessionType {
  work
  rest
}
